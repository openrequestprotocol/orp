{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openrequestprotocol.org/schemas/v0.2/discovery.json",
  "title": "ORP Discovery Document",
  "description": "Published at https://<domain>/.well-known/orp",
  "type": "object",
  "required": ["v", "endpoint", "public_keys"],
  "additionalProperties": false,
  "properties": {
    "v": { "type": "string", "const": "0.2" },
    "endpoint": { "type": "string", "format": "uri" },
    "public_keys": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["key_id", "alg", "value"],
        "properties": {
          "key_id": { "type": "string" },
          "alg": { "type": "string", "const": "ed25519" },
          "value": { "type": "string", "description": "Base64url-encoded public key" }
        }
      }
    },
    "policy_url": { "type": "string", "format": "uri" },
    "limits": {
      "type": "object",
      "properties": {
        "max_payload_bytes": { "type": "integer", "minimum": 1024, "default": 262144 },
        "max_summary_len": { "type": "integer", "minimum": 32, "default": 280 }
      }
    }
  }
}
