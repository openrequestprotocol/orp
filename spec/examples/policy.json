{
  "v": "0.2",
  "recipient": "bob@example.com",
  "accepts": {
    "intents": ["reply", "decide", "pay", "sign", "schedule", "read", "fyi"],
    "require": ["summary"]
  },
  "senders": {
    "vip_bypass": true,
    "unknown": "stake_required",
    "blocked": [],
